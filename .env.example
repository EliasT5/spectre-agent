# Shell → core connection
CORE_URL=http://127.0.0.1:8787
CORE_TOKEN=<must match the core's CORE_TOKEN>

# Shell-edge PIN auth (the core does not do PIN)
PIN_HASH=<sha256 of your PIN: node -e "console.log(require('crypto').createHash('sha256').update('YOURPIN').digest('hex'))">
SESSION_SECRET=<random hex>

# (No Supabase values: the browser holds no storage credentials — chat streams
# over the core's /api/threads/:id/stream SSE feed through the proxy.)
