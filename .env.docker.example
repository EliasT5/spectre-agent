# Spectre — full-stack Docker env (shell + core). Written by
# `node installer/install.mjs`; copy to `.env.docker` and fill in to configure by
# hand. `.env.docker` is gitignored — never commit real values. Every service in
# docker-compose.yml reads this file.

# ── Core capability token ────────────────────────────────────────────────────
# Random 32-byte hex. The shell injects it on every proxied /api request; the
# core trusts it (x-spectre-core-token). The installer generates this for you.
CORE_TOKEN=

# ── Shell PIN gate ───────────────────────────────────────────────────────────
# SHA-256 hex of your PIN. The raw PIN is NEVER stored (the installer hashes it).
PIN_HASH=
# Random hex for session signing.
SESSION_SECRET=

# ── Storage ──────────────────────────────────────────────────────────────────
# Two options; the installer picks one for you.
#
# (A) LOCAL & FREE (default): the installer brings up a bundled, trimmed
#     self-hosted Supabase (Postgres+pgvector, PostgREST, Realtime, Kong) from
#     local-db/docker-compose.yml, generates the JWT keys, and applies
#     supabase/_apply_all.sql. It then writes these for you:
#       SUPABASE_URL=http://host.docker.internal:8000   # core/containers → host loopback
#       NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000   # core fallback URL
#       SUPABASE_SERVICE_ROLE_KEY = generated HS256 key
#     (Needs `host.docker.internal:host-gateway`, already set on the core +
#     runner services; Linux resolves it via host-gateway.)
#     The browser never gets storage credentials — chat rides the core's SSE
#     thread stream through the /api proxy, so there is NO anon key here.
#
# (B) CLOUD: your own hosted Supabase project — fill these in:
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service role key>

# ── Provider API keys (optional; leave blank or omit to skip) ────────────────
# The installer auto-detects keys present in your shell env and offers to copy
# them. Any key you set here is forwarded to the LiteLLM gateway; providers
# whose key is absent are simply unavailable for model selection. The installer
# only writes keys you actually provide -- it never emits KEY="" entries.
ANTHROPIC_API_KEY=          # https://console.anthropic.com
OPENAI_API_KEY=             # https://platform.openai.com
GOOGLE_GENAI_API_KEY=       # https://aistudio.google.com
OPENROUTER_API_KEY=         # https://openrouter.ai
GROQ_API_KEY=               # https://console.groq.com
MISTRAL_API_KEY=            # https://console.mistral.ai
DEEPSEEK_API_KEY=           # https://platform.deepseek.com
XAI_API_KEY=                # https://console.x.ai
TOGETHER_API_KEY=           # https://api.together.ai
FIREWORKS_API_KEY=          # https://fireworks.ai
CEREBRAS_API_KEY=           # https://cloud.cerebras.ai
PERPLEXITY_API_KEY=         # https://perplexity.ai
HF_TOKEN=                   # https://huggingface.co/settings/tokens

# ── Local models (Ollama on the host; container reaches host.docker.internal) ─
OLLAMA_DISTILL_MODEL=gemma3
OLLAMA_LEARN_MODEL=gemma3
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Networking ───────────────────────────────────────────────────────────────
# Default loopback (localhost is a secure context, so the PIN cookie sets). Set
# SHELL_BIND=0.0.0.0 ONLY behind HTTPS (tailscale serve) — see docs/M6-INSTALLER.md.
SHELL_BIND=127.0.0.1
SHELL_PORT=3100
# The core is built from source (./core) and tagged spectre-core:local — there is
# no image to configure. Update with: git pull && docker compose up -d --build

# ── Messaging channels: Telegram (optional) ──────────────────────────────────
# Talk to Spectre from Telegram and get replies on the go. Setup:
#  1. Create a bot with @BotFather → paste its token below.
#  2. Pick a random secret (any hex) for TELEGRAM_WEBHOOK_SECRET.
#  3. Point Telegram at your PUBLIC shell URL (must be HTTPS-reachable):
#       curl "https://api.telegram.org/bot<TOKEN>/setWebhook" \
#         -d url="https://<your-host>/api/channels/telegram/webhook" \
#         -d secret_token="<TELEGRAM_WEBHOOK_SECRET>"
#  4. Find your numeric Telegram user id (e.g. via @userinfobot) and add it to
#     TELEGRAM_ALLOWED_SENDER_IDS (comma-separated). DEFAULT-DENY: empty = nobody.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_SENDER_IDS=

# ── Messaging channels: WhatsApp (optional, Meta Cloud API) ───────────────────
# Talk to Spectre from WhatsApp. Setup (developers.facebook.com → your app →
# WhatsApp):
#  1. Get the long-lived access token + your number's PHONE_NUMBER_ID.
#  2. Pick any random string for WHATSAPP_VERIFY_TOKEN (the webhook handshake).
#  3. Copy the App Secret (App settings → Basic) into WHATSAPP_APP_SECRET — it
#     verifies the X-Hub-Signature-256 HMAC on every inbound POST (fail-closed).
#  4. Configure the webhook → Callback URL: https://<your-host>/api/channels/whatsapp/webhook
#     Verify token: <WHATSAPP_VERIFY_TOKEN>. Subscribe to the `messages` field.
#  5. Add the sender phone numbers allowed to talk to Spectre (digits, no +) to
#     WHATSAPP_ALLOWED_SENDER_IDS (comma-separated). DEFAULT-DENY: empty = nobody.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ALLOWED_SENDER_IDS=
# WHATSAPP_GRAPH_VERSION=v21.0

# ── Messaging channels: Discord (optional) ────────────────────────────────────
# Talk to Spectre from Discord. Setup (discord.com/developers/applications):
#  1. New Application → Bot → Reset Token → paste into DISCORD_BOT_TOKEN.
#  2. Bot → enable the "MESSAGE CONTENT INTENT" (privileged) so it can read text.
#  3. OAuth2 → URL generator → scope `bot` + perms Send Messages / Read Message
#     History / Attach Files → open the URL to invite it to your server.
#  4. DM the bot, or @-mention it in a server channel.
#  5. Enable Developer Mode (Settings → Advanced), right-click yourself → Copy
#     User ID, add it to DISCORD_ALLOWED_SENDER_IDS. DEFAULT-DENY: empty = nobody.
#  No public URL needed — Discord uses an outbound Gateway connection.
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_SENDER_IDS=

# ── Workspaces (optional, opt-in: `docker compose --profile workspace up`) ─────
# In-browser code workspaces: sandbox repo clones (→ commit → PR → close) and/or
# TRUSTED local folders edited in place. Runs untrusted repo code (npm test /
# shell), so it's OFF by default and reachable only via the PIN-gated shell.
#  - WORKSPACE_SERVICE_TOKEN: shell→service auth (the installer generates one).
#  - GH_TOKEN: a GitHub token (repo scope) for clone / push / PR. Sandbox mode
#    needs it; trusted-folder push needs it too. Leave blank to disable cloning.
#  - WORKSPACE_TRUSTED_DIRS: comma-separated ABSOLUTE host paths to expose as
#    trusted folders. For each, ALSO add a bind-mount to the `workspace` (and
#    `code-server`) service in docker-compose.yml mapping it to the SAME path.
WORKSPACE_SERVICE_TOKEN=
GH_TOKEN=
WORKSPACE_TRUSTED_DIRS=
# Trusted-folder bind mount(s) for the Workspaces tab: "<host path>:/trusted/<name>".
# Add the matching "/trusted/<name>" to WORKSPACE_TRUSTED_DIRS above. Empty = none.
SPECTRE_TRUSTED_MOUNT_1=
# One-click updates: auth for the updater sidecar (compose `update` profile) that
# lets the web UI apply updates with a button. The installer generates one for UI
# installs. Empty ⇒ the button falls back to the update script. See
# agent-install/README.md "## Update".
UPDATER_TOKEN=
# code-server's own login password (the installer generates one). Defense in
# depth behind the shell PIN: the editor is file edit + terminal on the mounted
# workspaces, so it keeps its own gate even if a bind/edge config slips. Unset =
# code-server locks itself behind a random container-internal password (fail
# closed); CODE_SERVER_AUTH=none restores the old PIN-only behavior.
CODE_SERVER_PASSWORD=
# CODE_SERVER_AUTH=password
# The editor: code-server (VS Code) is embedded in the Workspaces tab via the
# `edge` proxy (Caddy), which serves it SAME-ORIGIN at /code (WebSockets + the
# Secure cookie need this). Access Spectre via the edge to use the editor:
#  - EDGE_PORT / EDGE_BIND: where the edge listens (default 127.0.0.1:8090).
#  - SPECTRE_SITE_ADDRESS: set to your domain (e.g. spectre.example.com) for
#    Caddy auto-HTTPS (then publish 80/443); leave blank for plain HTTP on :8090.
#  - NEXT_PUBLIC_CODE_SERVER_URL: where the tab loads the editor (BUILD-time).
#    Default "/code" (same-origin via the edge). For a quick localhost-only setup
#    you can instead build with http://localhost:8088 (the direct code-server port).
EDGE_PORT=8090
SPECTRE_SITE_ADDRESS=
NEXT_PUBLIC_CODE_SERVER_URL=/code

# ── Data-tool env exposure (optional) ─────────────────────────────────────────
# Declarative HTTP tools (data dir tools/*.json) may interpolate {env.NAME} into
# their URL/headers — but ONLY for names you list here. Everything else (incl.
# CORE_TOKEN / Supabase keys) is NEVER exposed to a tool. Comma-separated.
#   e.g. SPECTRE_TOOL_ENV_ALLOW=WEATHER_API_KEY,STRIPE_KEY
SPECTRE_TOOL_ENV_ALLOW=

# ── Spend safety ──────────────────────────────────────────────────────────────
# Hard per-run token cap (cumulative input+output across the agentic loop). Stops
# a runaway loop before it burns your metered API key; raise for very long runs,
# 0 disables. Default 2000000.
# SPECTRE_RUN_TOKEN_CAP=2000000

# ── CLI brains (Claude / Codex / Gemini) & custom backends ────────────────────
# Subscription "brains" run vendor CLIs on YOUR OWN subscription. All opt-in.
# These two runtime flags can ALSO be toggled in Settings → Danger Zone (no .env,
# no restart) — they're only here so you can pre-enable on first boot.
#  - SPECTRE_ALLOW_CLI_UI=1        manage/enable the CLI brains from Settings.
#  - SPECTRE_ALLOW_CLI_BACKENDS=1  allow "Add a CLI" / cli-command backends. These
#    SPAWN operator-supplied commands = RCE by design — enable only if you trust
#    what you add.
# SPECTRE_ALLOW_CLI_UI=1
# SPECTRE_ALLOW_CLI_BACKENDS=1
#
# INSTALL_CLIS is a BUILD-time flag (bundles the Claude + Codex CLI binaries into
# the core image). Set it, then rebuild core; it CANNOT be toggled at runtime.
# INSTALL_CLIS=1
#
# Per-CLI auth is set in Settings (no .env): Claude → a `claude setup-token` token;
# Codex → an OpenAI API key (or mount ~/.codex); Gemini → a Google AI API key.
#
# SPECTRE_MS_CLIENT_ID overrides the built-in Microsoft device-login client. For a
# reliable one-click sign-in, register your own multi-tenant Azure app and put its
# Application (client) ID here (the shipped default is flaky for personal accounts).
# SPECTRE_MS_CLIENT_ID=
