# Copy to .env.docker and fill in. Injected into the containers by compose.
# (.env.docker is gitignored; never commit real values.)
#
# Spectre's brain is PROVIDER-AGNOSTIC by default: the agentic loop runs against a
# LiteLLM gateway (or any OpenAI-compatible endpoint) using YOUR OWN API keys /
# self-hosted models. The subscription-driven CLI adapters (Claude/Codex/Gemini)
# are OFF by default — enable them for your own subscription via the flags below.

# Core auth — the shell injects this on every proxied request.
CORE_TOKEN=<random 32-byte hex>

# Storage (the user's Supabase project)
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key>
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service role key>

# ── THE STANDARD BRAIN: the LiteLLM gateway ──────────────────────────────────
# docker-compose points the core at the bundled litellm service automatically
# (SPECTRE_LITELLM_URL=http://litellm:4000/v1). You only set the master key, the
# model name, and the provider keys LiteLLM should use.
LITELLM_MASTER_KEY=sk-spectre
# Must match a model_name in litellm-config.yaml (default: the host's Ollama).
SPECTRE_LITELLM_MODEL=spectre-default
# Provider keys (uncomment the matching model in litellm-config.yaml). These are
# the metered API paths — your own keys, billed per token.
# ANTHROPIC_API_KEY=<sk-ant-…>
# OPENAI_API_KEY=<sk-…>
# GEMINI_API_KEY=<…>

# Local models (Ollama runs on the host; compose points the container at it).
OLLAMA_DISTILL_MODEL=gemma3
OLLAMA_LEARN_MODEL=gemma3
OLLAMA_EMBED_MODEL=nomic-embed-text

# Module signing (recommended once you install modules you didn't write):
# comma-separated base64url ed25519 public keys. When set, every non-builtin
# module manifest (DB install or data-dir drop-in) must be signed by one of
# these keys or it is hidden from the registry and refused at dispatch.
# Generate a keypair + sign manifests with: node scripts/sign-module.mjs
# SPECTRE_MODULE_TRUSTED_KEYS=<base64url pubkey>[,<another>]

# Self-evolution worker (only with `--profile self-evolve`): the target repo to
# edit (the shell/modules — NEVER the core). Absolute host path.
# SPECTRE_TARGET_REPO=/abs/path/to/your/modules-repo
# SPECTRE_BASE_BRANCH=main

# Monitor agent — which systemd services it tracks (Linux hosts). Comma-separated
# `name[:expected[:watchdog]]`; expected = required|optional (default required),
# append `:watchdog` for services whose own watchdog handles restarts (monitor
# observes only). Unset = monitor tracks no host services.
# SPECTRE_MONITORED_SERVICES=spectre-core:required,ollama:optional

# ── Subscription-driven CLI adapters — OFF BY DEFAULT ────────────────────────
# Script your OWN Claude / Codex / Gemini subscription through the vendor's own
# CLI / agent SDK, running on this machine. They're off by default (the gateway is
# the standard path); set a flag to 1 to opt one in for your own personal use, or
# toggle them live in Settings -> Providers when SPECTRE_ALLOW_CLI_UI=1. Keep them
# unset on shared / multi-user deployments — each uses a single personal login.
# USE AT YOUR OWN RISK: depending on the vendor + how you use it, driving a consumer
# subscription this way may be against its terms and could flag the account. That's
# part of why these are off by default.
# SPECTRE_ALLOW_CLAUDE_CLI=1   # Anthropic (Claude Code CLI)
# SPECTRE_ALLOW_CODEX_CLI=1    # OpenAI/ChatGPT (Codex CLI)
# SPECTRE_ALLOW_GEMINI_CLI=1   # Google (Gemini CLI)
# SPECTRE_ALLOW_CLI_UI=1       # allow toggling the three above from Settings
