# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/worker/node_modules
/spectre-mcp-broker/node_modules
/monitor/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store

# secrets / keys — never commit
*.pem
*.key
*.p12
*.pfx
secrets.json
*credentials*.json

# scratch / field reports / autonomous-loop drops — keep local, never ship
.loop-*/
*_FIELD_REPORT.md
HANDOFF.md

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example
!.env.docker.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
nul

# scratch / ideation drops — pasted screenshots and AI-generated UI drafts
# that we keep locally for reference but don't ship.
Screenshot*.png
/gemini-ui-suggestion/

# runtime artifacts generated on the deployed host
/.codex
/public/generated/
/.jerome-pdfs/
agents/voice/.venv/
data/voice-transcripts/
__pycache__/

# SkillOpt — PER-INSTANCE / PERSONAL data (the open-core ships only the generic
# seed.jsonl + the default skill docs; anything an install generates or evolves
# from its OWN conversation history stays local, never committed).
# NOTE: .gitignore has no inline comments — keep each pattern on its own line.
# tasks.jsonl = generated split (generic seed + harvested-from-own-history)
skillopt/envs/*/tasks.jsonl
# seed.local.jsonl = a user's own curated tasks (personal)
skillopt/envs/*/seed.local.jsonl
# best_skill.md / skill_v*.md = this install's evolved champion + candidate audit
skillopt/envs/*/best_skill.md
skillopt/envs/*/skill_v*.md
# any on-disk run logs/transcripts
skillopt/runs/

# bun-compiled core binaries
dist/

# Personal autonomous-loop harness — never ship
.build/

# local dev data-dir overlay (skills/tools/mcp)
.data/

