{
  "$schema": "https://json.schemastore.org/claude-code-settings",
  "_comment": "Allowlist for Spectre's own self-edit Claude Code runs. Pre-approves common dev commands so the harness doesn't block on every tool use. Reads stay broad; writes/exec narrow.",
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npx tsc:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo view:*)",
      "Bash(curl http://127.0.0.1:*)",
      "Bash(curl https://127.0.0.1:*)",
      "Bash(curl -sf http://localhost:*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "mcp__spectre__notify",
      "mcp__spectre__tools_list",
      "mcp__spectre__memory.add",
      "mcp__spectre__memory.search",
      "mcp__spectre__memory.delete",
      "mcp__spectre__memory_add",
      "mcp__spectre__memory_search",
      "mcp__spectre__memory_delete",
      "mcp__spectre__calendar.today",
      "mcp__spectre__calendar.upcoming",
      "mcp__spectre__calendar_today",
      "mcp__spectre__calendar_upcoming",
      "mcp__spectre__analytics_usage",
      "mcp__spectre__analytics.usage",
      "mcp__spectre__questionnaire_ask",
      "mcp__spectre__questionnaire.ask",
      "mcp__spectre__workshop_list",
      "mcp__spectre__workshop_create",
      "mcp__spectre__workshop_get",
      "mcp__spectre__workshop_execute",
      "mcp__spectre__workshop_abort",
      "mcp__spectre__workshop_push",
      "mcp__spectre__workshop_preview",
      "mcp__spectre__workshop_discard",
      "mcp__spectre__workshop.list",
      "mcp__spectre__workshop.create",
      "mcp__spectre__workshop.get",
      "mcp__spectre__workshop.execute",
      "mcp__spectre__workshop.abort",
      "mcp__spectre__workshop.push",
      "mcp__spectre__workshop.preview",
      "mcp__spectre__workshop.discard",
      "mcp__spectre__schedule_create",
      "mcp__spectre__schedule_list",
      "mcp__spectre__schedule_get",
      "mcp__spectre__schedule_update",
      "mcp__spectre__schedule_run_now",
      "mcp__spectre__schedule_delete",
      "mcp__spectre__schedule.create",
      "mcp__spectre__schedule.list",
      "mcp__spectre__schedule.get",
      "mcp__spectre__schedule.update",
      "mcp__spectre__schedule.run_now",
      "mcp__spectre__schedule.delete",
      "mcp__spectre__gemini_execute",
      "mcp__spectre__openai_image",
      "mcp__spectre__openai_chat",
      "mcp__spectre__gemini.execute",
      "mcp__spectre__openai.image",
      "mcp__spectre__openai.chat",
      "mcp__spectre_mode__tools_list",
      "mcp__spectre_mode__tools.list",
      "mcp__spectre_mode__dispatch_to_model",
      "mcp__spectre_mode__openai_image",
      "mcp__spectre_mode__openai_chat",
      "mcp__spectre_mode__openai.image",
      "mcp__spectre_mode__openai.chat"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(systemctl:*)",
      "Bash(curl https://api.openai.com:*)"
    ]
  }
}
